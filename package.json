{
  "name": "apollo-datasource-4-mongo",
  "version": "0.3.1",
  "description": "Apollo data source for MongoDB Client and Mongoose",
  "main": "dist/index.js",
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:clear-cache": "jest --clearCache",
    "lint": "eslint .",
    "clean": "rimraf dist",
    "lint-fix": "eslint --fix .",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build",
    "preversion": "npm run prettify && npm run lint && npm test && npm run build",
    "prettify": "prettier --write **/*.ts",
    "version": "standard-changelog && git add CHANGELOG.md"
  },
  "engines": {
    "node": ">=8"
  },
  "dependencies": {
    "@apollo/utils.keyvaluecache": "^4.0.0",
    "dataloader": "^2.0.0",
    "mongodb": "4.17.0",
    "sift": "^13.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.27.0",
    "eslint-plugin-prettier": "^5.0.0",
    "graphql": "^16.0.0",
    "husky": "^8.0.0",
    "jest": "^29.5.0",
    "lint-staged": "^14.0.0",
    "mongoose": "^9.6.2",
    "prettier": "^3.0.0",
    "standard-changelog": "^2.0.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "waait": "^1.0.4"
  },
